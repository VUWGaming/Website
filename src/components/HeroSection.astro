---
---

<section
	id="home"
	class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center"
>
	<!-- Gradient blob background -->
	<div
		class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center"
		aria-hidden="true"
	>
		<div class="h-[600px] w-[600px] rounded-full bg-violet-700/20 blur-[120px]"></div>
		<div
			class="absolute h-[400px] w-[400px] translate-x-32 translate-y-16 rounded-full bg-fuchsia-700/20 blur-[100px]"
		>
		</div>
	</div>

	<div class="max-w-3xl">
		<span
			class="mb-6 inline-block rounded-full border border-violet-500/30 bg-violet-500/10 px-4 py-1.5 text-sm font-medium text-violet-300"
		>
			<span aria-hidden="true">🎮</span> Victoria University of Wellington
		</span>
		<h1 class="mb-6 text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
			Play. Connect.
			<span class="bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent"
				>Level Up.</span
			>
		</h1>
		<p class="mx-auto mb-10 max-w-xl text-lg text-gray-400 sm:text-xl">
			VUW Gaming Club is the home for gamers on campus — from casual Friday nights to competitive
			esports. All skill levels welcome.
		</p>
		<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
			<a
				href="#join"
				class="rounded-xl bg-violet-600 px-8 py-3 text-base font-semibold text-white shadow-lg shadow-violet-900/40 transition-all hover:bg-violet-500 hover:shadow-violet-700/50"
			>
				Join the Club
			</a>
			<a
				href="#events"
				class="rounded-xl border border-white/10 bg-white/5 px-8 py-3 text-base font-semibold text-gray-200 transition-all hover:border-white/20 hover:bg-white/10"
			>
				View Events
			</a>
		</div>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-gray-600">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			class="h-6 w-6"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
			aria-hidden="true"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M19 9l-7 7-7-7"></path>
		</svg>
	</div>
</section>
