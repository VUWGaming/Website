---

<section id="join" class="px-6 py-24">
	<div class="mx-auto max-w-2xl text-center">
		<div
			class="rounded-3xl border border-white/10 bg-gradient-to-b from-violet-950/60 to-gray-950/60 p-10 shadow-2xl shadow-violet-950/30"
		>
			<div class="mb-4 text-5xl" aria-hidden="true">🎮</div>
			<h2 class="mb-4 text-3xl font-bold sm:text-4xl">Ready to Join?</h2>
			<p class="mb-8 text-gray-400">
				Membership is free for all VUW students. Jump into our Discord to get started — introduce
				yourself, find your game, and join the next event.
			</p>
			<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
				<a
					href="https://discord.gg/"
					target="_blank"
					rel="noopener noreferrer"
					class="flex items-center gap-2 rounded-xl bg-[#5865F2] px-7 py-3 text-base font-semibold text-white transition-opacity hover:opacity-90"
				>
					<svg
						class="h-5 w-5"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 127.14 96.36"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.26 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
						></path>
					</svg>
					Join Discord
				</a>
				<a
					href="mailto:gaming@vuw.ac.nz"
					class="rounded-xl border border-white/10 bg-white/5 px-7 py-3 text-base font-semibold text-gray-200 transition-all hover:border-white/20 hover:bg-white/10"
				>
					Email Us
				</a>
			</div>
		</div>
	</div>
</section>
