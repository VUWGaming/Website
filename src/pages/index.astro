---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const events = [
	{
		date: 'Apr 19',
		title: 'Weekly Smash Bros Night',
		description: 'Open bracket tournament — any skill level welcome. Bring your controller!',
		tag: 'Fighting',
		tagColor: 'bg-red-500/20 text-red-300',
		emoji: '🥊',
	},
	{
		date: 'Apr 23',
		title: 'Valorant 5v5 Scrimmage',
		description: 'Internal 5v5 competitive match. Sign up in Discord to reserve your spot.',
		tag: 'FPS',
		tagColor: 'bg-blue-500/20 text-blue-300',
		emoji: '🎯',
	},
	{
		date: 'Apr 26',
		title: 'Board Game & Tabletop RPG Night',
		description: "Catan, D&D, and more. Bring your friends or come solo — we'll find you a table.",
		tag: 'Tabletop',
		tagColor: 'bg-green-500/20 text-green-300',
		emoji: '🎲',
	},
	{
		date: 'May 3',
		title: 'Speedrunning Workshop',
		description:
			'Learn the basics of speedrunning and glitch hunting. Any-% tips and tricks from club veterans.',
		tag: 'Workshop',
		tagColor: 'bg-yellow-500/20 text-yellow-300',
		emoji: '⏱️',
	},
	{
		date: 'May 10',
		title: 'End-of-Trimester LAN Party',
		description:
			'Three-hour LAN session in the Kelburn Campus Hub. BYO laptop or use club equipment.',
		tag: 'LAN',
		tagColor: 'bg-violet-500/20 text-violet-300',
		emoji: '💻',
	},
	{
		date: 'May 17',
		title: 'Rocket League Tournament',
		description: '2v2 round-robin tournament with prizes. Register your team by May 15.',
		tag: 'Racing',
		tagColor: 'bg-orange-500/20 text-orange-300',
		emoji: '🚀',
	},
];
---

<Layout>
	<Navbar />

	<!-- Hero -->
	<section
		id="home"
		class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 text-center"
	>
		<!-- Gradient blob background -->
		<div
			class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center"
			aria-hidden="true"
		>
			<div
				class="h-[600px] w-[600px] rounded-full bg-violet-700/20 blur-[120px]"
			>
			</div>
			<div
				class="absolute h-[400px] w-[400px] translate-x-32 translate-y-16 rounded-full bg-fuchsia-700/20 blur-[100px]"
			>
			</div>
		</div>

		<div class="max-w-3xl">
			<span
				class="mb-6 inline-block rounded-full border border-violet-500/30 bg-violet-500/10 px-4 py-1.5 text-sm font-medium text-violet-300"
			>
				🎮 Victoria University of Wellington
			</span>
			<h1 class="mb-6 text-5xl font-extrabold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
				Play. Connect.
				<span class="bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent"
					>Level Up.</span
				>
			</h1>
			<p class="mx-auto mb-10 max-w-xl text-lg text-gray-400 sm:text-xl">
				VUW Gaming Club is the home for gamers on campus — from casual Friday nights to competitive
				esports. All skill levels welcome.
			</p>
			<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
				<a
					href="#join"
					class="rounded-xl bg-violet-600 px-8 py-3 text-base font-semibold text-white shadow-lg shadow-violet-900/40 transition-all hover:bg-violet-500 hover:shadow-violet-700/50"
				>
					Join the Club
				</a>
				<a
					href="#events"
					class="rounded-xl border border-white/10 bg-white/5 px-8 py-3 text-base font-semibold text-gray-200 transition-all hover:border-white/20 hover:bg-white/10"
				>
					View Events
				</a>
			</div>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-gray-600">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				class="h-6 w-6"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M19 9l-7 7-7-7"></path>
			</svg>
		</div>
	</section>

	<!-- About -->
	<section id="about" class="px-6 py-24">
		<div class="mx-auto max-w-6xl">
			<div class="mb-16 text-center">
				<h2 class="mb-4 text-3xl font-bold sm:text-4xl">About Us</h2>
				<p class="mx-auto max-w-2xl text-gray-400">
					We're a student-run club at Te Herenga Waka — Victoria University of Wellington, united by
					a love of games.
				</p>
			</div>

			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					[
						{
							icon: '🏆',
							title: 'Competitive Esports',
							description:
								'Represent VUW in inter-university esports competitions across Valorant, League of Legends, Rocket League, and more.',
						},
						{
							icon: '🤝',
							title: 'Casual & Social',
							description:
								'Weekly hangouts, board game nights, and LAN parties for players who just want to have fun.',
						},
						{
							icon: '📚',
							title: 'Learn & Grow',
							description:
								'Workshops, coaching sessions, and mentorship from experienced players to help you improve.',
						},
						{
							icon: '🌐',
							title: 'Active Community',
							description:
								'Our Discord server is buzzing 24/7 — find teammates, share clips, and stay up to date on events.',
						},
						{
							icon: '🎁',
							title: 'Member Perks',
							description:
								'Members get early access to tournaments, exclusive club merch, and discounts from our gaming partners.',
						},
						{
							icon: '📍',
							title: 'On-Campus Space',
							description:
								'We have a dedicated gaming lounge on the Kelburn campus, open to members throughout the week.',
						},
					].map(({ icon, title, description }) => (
						<div class="rounded-2xl border border-white/5 bg-white/5 p-6 transition-colors hover:border-violet-500/30 hover:bg-white/[0.07]">
							<div class="mb-3 text-3xl">{icon}</div>
							<h3 class="mb-2 text-lg font-semibold">{title}</h3>
							<p class="text-sm leading-relaxed text-gray-400">{description}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Events -->
	<section id="events" class="px-6 py-24">
		<div class="mx-auto max-w-6xl">
			<div class="mb-16 text-center">
				<h2 class="mb-4 text-3xl font-bold sm:text-4xl">Upcoming Events</h2>
				<p class="mx-auto max-w-2xl text-gray-400">
					From weekly hangouts to semester-wide tournaments — there's always something on.
				</p>
			</div>

			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					events.map(({ date, title, description, tag, tagColor, emoji }) => (
						<div class="flex flex-col rounded-2xl border border-white/5 bg-white/5 p-6 transition-colors hover:border-violet-500/30 hover:bg-white/[0.07]">
							<div class="mb-4 flex items-start justify-between gap-2">
								<span class={`rounded-full px-3 py-1 text-xs font-medium ${tagColor}`}>{tag}</span>
								<span class="text-sm font-medium text-gray-500">{date}</span>
							</div>
							<div class="mb-2 text-3xl">{emoji}</div>
							<h3 class="mb-2 text-lg font-semibold">{title}</h3>
							<p class="text-sm leading-relaxed text-gray-400">{description}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Join -->
	<section id="join" class="px-6 py-24">
		<div class="mx-auto max-w-2xl text-center">
			<div
				class="rounded-3xl border border-white/10 bg-gradient-to-b from-violet-950/60 to-gray-950/60 p-10 shadow-2xl shadow-violet-950/30"
			>
				<div class="mb-4 text-5xl">🎮</div>
				<h2 class="mb-4 text-3xl font-bold sm:text-4xl">Ready to Join?</h2>
				<p class="mb-8 text-gray-400">
					Membership is free for all VUW students. Jump into our Discord to get started — introduce
					yourself, find your game, and join the next event.
				</p>
				<div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
					<a
						href="https://discord.gg/"
						target="_blank"
						rel="noopener noreferrer"
						class="flex items-center gap-2 rounded-xl bg-[#5865F2] px-7 py-3 text-base font-semibold text-white transition-opacity hover:opacity-90"
					>
						<svg
							class="h-5 w-5"
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 127.14 96.36"
							fill="currentColor"
						>
							<path
								d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
							></path>
						</svg>
						Join Discord
					</a>
					<a
						href="mailto:gaming@vuw.ac.nz"
						class="rounded-xl border border-white/10 bg-white/5 px-7 py-3 text-base font-semibold text-gray-200 transition-all hover:border-white/20 hover:bg-white/10"
					>
						Email Us
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="border-t border-white/5 px-6 py-10">
		<div
			class="mx-auto flex max-w-6xl flex-col items-center gap-4 text-center sm:flex-row sm:justify-between sm:text-left"
		>
			<div class="flex items-center gap-2 text-sm font-semibold">
				<span>🎮</span>
				<span class="bg-gradient-to-r from-violet-400 to-fuchsia-400 bg-clip-text text-transparent">
					VUW Gaming Club
				</span>
			</div>
			<p class="text-sm text-gray-500">
				© {new Date().getFullYear()} VUW Gaming Club · Te Herenga Waka — Victoria University of Wellington
			</p>
			<div class="flex gap-4 text-sm text-gray-500">
				<a href="https://discord.gg/" class="transition-colors hover:text-gray-300">Discord</a>
				<a href="https://instagram.com/" class="transition-colors hover:text-gray-300">Instagram</a>
				<a href="mailto:gaming@vuw.ac.nz" class="transition-colors hover:text-gray-300">Contact</a>
			</div>
		</div>
	</footer>
</Layout>
